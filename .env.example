# Copiar a .env y completar con valores reales (NO subir .env al repo)

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Alternativas al archivo (utiles para PaaS / Streamlit Cloud):
#   GOOGLE_SHEETS_CREDENTIALS_JSON  -> JSON de la Service Account como string
#   GOOGLE_SHEETS_CREDENTIALS_B64   -> mismo JSON codificado en base64
# GOOGLE_SHEETS_CREDENTIALS_JSON=
# GOOGLE_SHEETS_CREDENTIALS_B64=

# Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID_MEDICO=tu_chat_id_aqui
# Nota: TELEGRAM_CHAT_ID_MEDICO es el chat de fallback.
# Cada medico recibe sus recordatorios en su propio chat (campo telegram_chat_id del Sheet).
# Si un medico no tiene telegram_chat_id configurado, se usa este valor.
