# Copiar a .streamlit/secrets.toml y completar con valores reales.
# Este archivo NO se sube al repo (ver .gitignore).
# En Streamlit Community Cloud se configura desde la web:
#   Settings -> Secrets (pegar este mismo contenido).

# Opcion A (recomendada en Streamlit Cloud): pegar la Service Account
# como una tabla TOML. Equivale al contenido de credentials.json.
[gcp_service_account]
type = "service_account"
project_id = "kayla-xxxxx"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key = """-----BEGIN PRIVATE KEY-----
MIIE...tu_llave_privada_aqui...==
-----END PRIVATE KEY-----"""
client_email = "kayla-sa@kayla-xxxxx.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/kayla-sa%40kayla-xxxxx.iam.gserviceaccount.com"

# Opcion B: pegar el JSON completo de credentials.json como un string.
# Si usas esta opcion, comenta/elimina la tabla [gcp_service_account] de arriba.
# GOOGLE_SHEETS_CREDENTIALS_JSON = '{ "type": "service_account", ... }'

# ID del Google Sheet de pacientes (extraido de la URL del Sheet).
GOOGLE_SHEETS_SPREADSHEET_ID = "tu_spreadsheet_id_aqui"

# Telegram (el dashboard no envia mensajes, pero se deja por consistencia).
TELEGRAM_BOT_TOKEN = "tu_token_aqui"
TELEGRAM_CHAT_ID_MEDICO = "tu_chat_id_aqui"
